@{
    ViewData["Title"] = "Traductor de Voz";
}

<div class="container">
    <h1 class="mt-4 text-white">Traductor de Voz</h1>
    <h4 class="text-success mb-3">Graba y traduce hasta en 4 diferentes idiomas.</h4>

    <h5 class="text-white">Intentalo:</h5>
    <div class="mb-3 bg-dark text-white p-4 audio-box">
        <button id="btnGrabar" class="btn btn-danger me-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-mic-fill" viewBox="0 0 16 16">
                <path d="M5 3a3 3 0 0 1 6 0v5a3 3 0 0 1-6 0z" />
                <path d="M3.5 6.5A.5.5 0 0 1 4 7v1a4 4 0 0 0 8 0V7a.5.5 0 0 1 1 0v1a5 5 0 0 1-4.5 4.975V15h3a.5.5 0 0 1 0 1h-7a.5.5 0 0 1 0-1h3v-2.025A5 5 0 0 1 3 8V7a.5.5 0 0 1 .5-.5" />
            </svg>
            Iniciar
        </button>
        <button id="btnDetener" class="btn btn-secondary" disabled>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-stop-circle" viewBox="0 0 16 16">
                <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16" />
                <path d="M5 6.5A1.5 1.5 0 0 1 6.5 5h3A1.5 1.5 0 0 1 11 6.5v3A1.5 1.5 0 0 1 9.5 11h-3A1.5 1.5 0 0 1 5 9.5z" />
            </svg>
            Detener
        </button>
        <audio id="preview" class="mt-3" controls style="display:none;"></audio>
    </div>

    <label class="form-label text-white">Elige un idioma:</label>
    <select id="idiomaDestino" class="form-select mb-3">
        <option value="en">Inglés</option>
        <option value="pt">Portugués</option>
        <option value="fr">Francés</option>
        <option value="ja">Japonés</option>
    </select>

    <button id="btnProcesar" class="btn btn-dark" disabled>Traducir voz</button>

    <div id="resultado" class="mt-3"></div>
</div>


<script>
    let mediaRecorder;
    let chunks = [];
    let audioBlob;

    document.getElementById('btnGrabar').addEventListener('click', async () => {
        const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
        mediaRecorder = new MediaRecorder(stream);
        chunks = [];

        mediaRecorder.ondataavailable = e => chunks.push(e.data);
        mediaRecorder.onstop = () => {
            audioBlob = new Blob(chunks, { type: 'audio/webm' });
            const url = URL.createObjectURL(audioBlob);
            const preview = document.getElementById('preview');
            preview.src = url;
            preview.style.display = 'block';
            document.getElementById('btnProcesar').disabled = false;
        };

        mediaRecorder.start();
        document.getElementById('btnGrabar').disabled = true;
        document.getElementById('btnDetener').disabled = false;
    });

    document.getElementById('btnDetener').addEventListener('click', () => {
        mediaRecorder.stop();
        mediaRecorder.stream.getTracks().forEach(t => t.stop());
        document.getElementById('btnGrabar').disabled = false;
        document.getElementById('btnDetener').disabled = true;
    });

    document.getElementById('btnProcesar').addEventListener('click', async () => {
        const formData = new FormData();
        formData.append('audio', audioBlob, 'grabacion.webm');
        formData.append('idiomaDestino', document.getElementById('idiomaDestino').value);

        document.getElementById('resultado').innerHTML = 'Procesando...';

        const response = await fetch('/Voz/Procesar', {
            method: 'POST',
            body: formData
        });

        if (response.ok) {
            const blob = await response.blob();
            const url = URL.createObjectURL(blob);
            document.getElementById('resultado').innerHTML =
                `<audio controls src="${url}"></audio>`;
        } else {
            document.getElementById('resultado').innerHTML = 'Error al procesar el audio.';
        }
    });
</script>